    "import pandas as pd\n",
    "df = pd.read_csv(\"vinhos.csv\")\n",
    "media_populacao =  df[\"preco\"].mean()\n",
    "amostra = df.sample(frac=0.1,random_state=42)\n",
    "media_amostra = amostra[\"preco\"].mean()\n",
    "print(round(media_populacao,2),round(media_amostra,2))\n"
   ]
  }
